# ==================== Project ====================
PROJECT_NAME="Simurgh AI"
ENVIRONMENT=development
DEBUG=false
EXPOSE_DOCS=false

# ==================== Security ====================
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== Database ====================
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=stakeholder_db
# ==================== Database ====================

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ==================== AI / LLM ====================
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# ==================== RAG ====================
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==================== Email (Optional) ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_EMAIL=noreply@example.com
EMAIL_FROM_NAME="Simurgh AI"
RESEND_API_KEY=your-resend-api-key-here

# ==================== CORS ====================
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ==================== File Uploads ====================
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/tmp/uploads

# ==================== Feature Flags ====================
MAINTENANCE_MODE=false
THESIS_MODE=false
ENABLE_RAG=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=200
SKIP_EMAIL_VERIFICATION=false

# ==================== Worker Tuning ====================
# Uvicorn workers — formula: (2 x CPU cores) + 1
# e.g. 2-core VPS = 5, 4-core = 9. Start at 4 and tune under load.
UVICORN_WORKERS=4
# Celery concurrency — tasks in parallel per worker container
# Keep at 2-4 for AI-heavy workloads to avoid memory pressure
CELERY_CONCURRENCY=2

# ==================== Database Backups ====================
# How many daily backups to retain (older ones are auto-deleted)
BACKUP_RETAIN_DAYS=7

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== Integrations (Optional) ====================
JIRA_DEFAULT_INSTANCE_URL=https://your-domain.atlassian.net
JIRA_DEFAULT_USER_EMAIL=jira-user-email
JIRA_DEFAULT_API_TOKEN=jira-api-token